{
  "name": "dbt-js",
  "version": "0.1.3",
  "description": "A minimalist, dbt-like SQL transformation tool for Node.js — compile SQL models, build a dependency DAG, and materialize them on any supported SQL database.",
  "type": "module",
  "main": "./dist/dbt-js.cjs",
  "module": "./src/api.js",
  "exports": {
    ".": {
      "import": "./src/api.js",
      "require": "./dist/dbt-js.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "dbt-js": "bin/dbt-js.js"
  },
  "scripts": {
    "build": "esbuild src/api.js --bundle --platform=node --format=cjs --target=node20 --packages=external --outfile=dist/dbt-js.cjs",
    "prepack": "npm run build"
  },
  "license": "MIT",
  "author": "Shahzad Hamza",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shahzadhamza/dbt-js.git"
  },
  "homepage": "https://github.com/shahzadhamza/dbt-js.git#readme",
  "bugs": {
    "url": "https://github.com/shahzadhamza/dbt-js/issues"
  },
  "keywords": [
    "dbt",
    "sql",
    "postgres",
    "mysql",
    "sqlite",
    "duckdb",
    "etl",
    "elt",
    "data-transformation",
    "dag",
    "analytics"
  ],
  "files": [
    "bin",
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.3-r.3",
    "better-sqlite3": "~12.9.0",
    "csv-parse": "^5.6.0",
    "mysql2": "^3.11.0",
    "pg": "^8.13.0"
  }
}
